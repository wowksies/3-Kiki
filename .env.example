# Fine-grained GitHub token with read+write Contents on wowksies/3-Kirwan.
# Get one at https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Repo coords (defaults shown — override only if forking)
GITHUB_OWNER=wowksies
GITHUB_REPO=3-Kirwan
GITHUB_BRANCH=main

# Shared PIN classmates type on /upload.
# DO NOT commit the real value — set it in .env.local (local) and Vercel env vars (prod).
UPLOAD_PIN=
